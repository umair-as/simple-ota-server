# OTA Server Configuration

# URL devices use to download bundles.
# Must be reachable from your IoT devices.
# Use ota-gw.local if mDNS resolves on your LAN, otherwise use the server IP.
SERVER_URL=https://ota-gw.local:8443

# Optional: IP to advertise via mDNS for ota-gw.local.
# Required when the host has multiple interfaces on the same subnet (e.g. WiFi
# and ethernet both on 192.168.x.x) — set to the interface the devices are on.
# Find it with: ip route get <device-ip>
# Leave unset to auto-detect from the default route.
# MDNS_IP=192.168.1.100
